# ════════════════════════════════════════════════════════
# ds_churn — Churn Prediction Pipeline
# Unified .env.example — ALL secrets use CHANGE_ME placeholder
# Convention: 08-Security §5.3
# ════════════════════════════════════════════════════════

# ── Database (PostgreSQL) — for pipeline code ──────────
PG_HOST=CHANGE_ME
PG_PORT=5432
PG_DB=CHANGE_ME
PG_USER=CHANGE_ME
PG_PW=CHANGE_ME

# ── File System — Ingestion paths ──────────────────────
INCOMING_DIR=/data/incoming
SAVED_DIR=/data/saved
FAIL_DIR=/data/failed

# ── CSKH confirmed churn files ─────────────────────────
# Directory containing CSKH label ZIP files and label_YYMM CSV files
CSKH_DIR=/data/cskh
# Optional: Specific CSKH file path to mandate a single file mode
CSKH_FILE_PATH=

# ── Logging ────────────────────────────────────────────
LOGS_DIR=/logs

# ── Model paths ───────────────────────────────────────
CHURN_MODEL_DIR=./model_bundles

# ── Airflow (infrastructure/.env, NOT here) ────────────
# Airflow settings are stored in infrastructure/.env
# They should NOT be in the project root .env
