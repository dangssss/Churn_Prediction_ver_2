# ══════════════════════════════════════
# ds_churn — .gitignore
# ══════════════════════════════════════

# ── Python ─────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
*.whl
.eggs/

# ── Virtual environments ──────────────
venv/
.venv/
env/

# ── IDE ────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Env files with real secrets ────────
.env
!.env.example
config/.env.*

# ── Data & Artifacts (.gitignored) ─────
artifacts/
data/
logs/
*.pkl
*.joblib
*.h5
*.onnx
*.parquet
*.csv

# ── ML experiment tracking ─────────────
mlruns/
wandb/

# ── OS files ───────────────────────────
.DS_Store
Thumbs.db

# ── Notebook checkpoints ──────────────
.ipynb_checkpoints/
